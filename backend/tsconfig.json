{
  "compilerOptions": {
    "target": "ES2020",
    "types": ["vitest/globals"],
    "typeRoots": ["./types", "./node_modules/@types", "./node_modules"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": "./src",
    "strict": true,
    "paths": {
      "@app/*": ["./src/app/*"]
    },
    "skipLibCheck": true
  },
  "include": ["src"]
}
