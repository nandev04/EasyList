{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ESNext"],
    "types": ["vitest/globals"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": "./src",
    "strict": true,
    "paths": {
      "@app/*": ["./src/app/*"]
    },
    "skipLibCheck": true
  },
  "include": ["src"]
}
