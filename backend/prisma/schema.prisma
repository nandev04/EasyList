generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  firstname    String
  lastname     String
  username     String
  email        String   @unique
  password     String
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tokenVersion Int      @default(0)
  avatarKey    String?

  tasks                    Task[]
  refreshTokens            RefreshToken[]
  PasswordResetCode        PasswordResetOTP[]
  PasswordResetToken       PasswordResetToken[]
  devices                  Device[]
  EmailResetCode           UpdateEmailOTP[]
  accountVerificationToken AccountVerificationToken[]
}

model AccountVerificationToken {
  id        Int       @id @default(autoincrement())
  tokenHash String    @unique
  userId    String
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  used      Boolean   @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Device {
  id         Int      @id @default(autoincrement())
  deviceUUID String   @unique
  userId     String
  createdAt  DateTime @default(now())

  refreshToken RefreshToken[]
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  deviceId  Int
  token     String    @unique
  userId    String
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model PasswordResetOTP {
  id        Int      @id @default(autoincrement())
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  used      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, used, expiresAt, id])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UpdateEmailOTP {
  id        Int      @id @default(autoincrement())
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
  new_email String
  userId    String
  used      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tokenHash, expiresAt, used])
}
